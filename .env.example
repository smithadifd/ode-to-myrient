# ode-to-myrient configuration
# Copy this to .env and fill in your values.

# Where to save downloaded ROMs (absolute path)
# Each console gets its own subdirectory inside this path.
DOWNLOAD_DIR=./roms

# Number of parallel Playwright workers (default: 3)
# More workers = faster, but higher risk of rate limiting.
WORKERS=3

# Discord webhook URL for notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=

# Run browser in headless mode? (true/false, default: false)
# Set to false initially to watch downloads work, then switch to true.
HEADLESS=false

# Base delay between downloads per worker, in milliseconds (default: 3000)
BASE_DELAY_MS=3000

# Maximum retries per file before logging failure (default: 3)
MAX_RETRIES=3
